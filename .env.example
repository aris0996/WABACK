FLASK_ENV=production
APP_PORT=5000
APP_TIMEZONE=Asia/Makassar
SECRET_KEY=change-this-secret

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Empty means WAHA webhook does not require token.
WEBHOOK_TOKEN=
WAHA_WEBHOOK_REQUIRE_TOKEN=false

DATABASE_URL=sqlite:///data/app.db

DEFAULT_WAHA_BASE_URL=http://127.0.0.1:3000
DEFAULT_WAHA_SESSION=default
DEFAULT_WAHA_API_KEY=

DEFAULT_OLLAMA_BASE_URL=http://127.0.0.1:11434
DEFAULT_CHATBOT_MODEL=wa-chatbot
DEFAULT_EXTRACTOR_MODEL=wa-memory-extractor
DEFAULT_MERGER_MODEL=wa-memory-merger

DEFAULT_GLOBAL_AUTO_REPLY=true
DEFAULT_MEMORY_AUTO_GENERATE=true
DEFAULT_MEMORY_GENERATE_INTERVAL=20

LOG_RETENTION_DAYS=14

# GitHub auto update webhook
# GitHub webhook URL: http://SERVER:PORT/webhook/github
# Recommended: set this as GitHub webhook Secret for X-Hub-Signature-256 verification.
GITHUB_WEBHOOK_SECRET=change-this-github-webhook-secret
# Optional extra API key. If set, send header X-Update-Key or X-Api-Key with this value.
AUTO_UPDATE_API_KEY=
# Optional branch guard, for example main. Empty means use current branch.
AUTO_UPDATE_BRANCH=main
# Optional command after git pull succeeds. Example for host deployment:
# AUTO_UPDATE_COMMAND=docker compose up -d --build
AUTO_UPDATE_COMMAND=
AUTO_UPDATE_TIMEOUT=300
AUTO_UPDATE_RESTART_WORKER=true
LOG_RETENTION_DAYS=14
